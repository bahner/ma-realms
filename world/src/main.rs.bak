#[derive(Clone, Debug, Deserialize, Default)]
struct AppConfig {
    #[serde(default)]
    kubo_api_url: Option<String>,
    #[serde(default)]
    listen: Option<String>,
    #[serde(default)]
    world_slug: Option<String>,
    #[serde(default)]
    world_dir: Option<String>,
    #[serde(default)]
    log_level: Option<String>,
    #[serde(default)]
    log_file: Option<String>,
    #[serde(default)]
    owner_did: Option<String>,
}

fn app_config_base_dir() -> PathBuf {
    if let Some(config_home) = std::env::var_os("XDG_CONFIG_HOME") {
        return PathBuf::from(config_home).join("ma");
    }
    if let Some(home) = std::env::var_os("HOME") {
        return PathBuf::from(home).join(".config").join("ma");
    }
    PathBuf::from(".")
}

fn app_config_paths_for_world(world_slug: &str) -> (PathBuf, PathBuf) {
    let base = app_config_base_dir();
    let flat = base.join(format!("{}.yaml", world_slug));
    let nested = base.join(world_slug).join("config.yaml");
    (flat, nested)
}

fn resolve_app_config_path(world_slug: &str, cli_config_override: &Option<PathBuf>) -> PathBuf {
    if let Some(path) = cli_config_override {
        return path.clone();
    }

    let (flat, nested) = app_config_paths_for_world(world_slug);
    if flat.exists() {
        return flat;
    }
    if nested.exists() {
        return nested;
    }

    // Default target when creating a new config for this world.
    flat
}

fn load_app_config(path: &Path) -> Result<AppConfig> {
    if !path.exists() {
        return Ok(AppConfig::default());
    }
    let raw = fs::read_to_string(&path)
        .map_err(|e| anyhow!("failed reading app config {}: {}", path.display(), e))?;
    let parsed: AppConfig = serde_yaml::from_str(&raw)
        .map_err(|e| anyhow!("invalid app config {}: {}", path.display(), e))?;
    Ok(parsed)
}

fn extract_global_config_arg(raw_args: Vec<String>) -> Result<(Vec<String>, Option<PathBuf>)> {
    let mut args = Vec::with_capacity(raw_args.len());
    let mut config_override: Option<PathBuf> = None;

    if let Some(program) = raw_args.first() {
        args.push(program.clone());
    }

    let mut idx = 1usize;
    while idx < raw_args.len() {
        match raw_args[idx].as_str() {
            "--config" => {
                idx += 1;
                if idx >= raw_args.len() {
                    return Err(anyhow!("missing value for --config"));
                }
                config_override = Some(PathBuf::from(&raw_args[idx]));
            }
            _ => args.push(raw_args[idx].clone()),
        }
        idx += 1;
    }

    Ok((args, config_override))
}

fn scan_world_slug_arg(args: &[String]) -> Option<String> {
    let mut idx = 1usize;
    while idx < args.len() {
        if args[idx] == "--world-slug" {
            idx += 1;
            if idx < args.len() {
                return Some(args[idx].clone());
            }
            return None;
        }
        idx += 1;
    }
    None
}

#[derive(Clone, Debug)]
struct CachedDidDocument {
    document: Document,
    fetched_at: Instant,
}

#[derive(Clone, Debug)]
pub(crate) struct AvatarRequest {
    pub inbox: String,
    pub did: Did,
    pub agent_endpoint: String,
}

