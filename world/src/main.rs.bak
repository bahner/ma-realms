#[derive(Debug, Deserialize)]
#[serde(tag = "kind", rename_all = "snake_case")]
enum WorldRequest {
    /// Legacy command path: message content is a serialised WorldCommand.
    Signed { message_cbor: Vec<u8> },
    /// Plain signed chat message; room is specified in the wrapper.
    Chat { room: String, message_cbor: Vec<u8> },
    /// E2E-encrypted whisper; recipient DID is visible in signed message `to`.
    Whisper { message_cbor: Vec<u8> },
}

#[derive(Debug, Deserialize)]
#[serde(tag = "kind", rename_all = "snake_case")]
enum WorldCommand {
    Enter {
        room: Option<String>,
        /// Preferred handle; defaults to DID fragment. Disambiguated by world on collision.
        #[serde(default)]
        preferred_handle: Option<String>,
    },
    Message {
        room: String,
        envelope: MessageEnvelope,
    },
    RoomEvents {
        room: String,
        since_sequence: u64,
    },
}

#[derive(Clone, Debug, Serialize, Deserialize)]
struct RoomEvent {
    sequence: u64,
    room: String,
    kind: String,
    sender: Option<String>,
    #[serde(skip_serializing_if = "Option::is_none")]
    sender_did: Option<String>,
    #[serde(skip_serializing_if = "Option::is_none")]
    sender_endpoint: Option<String>,
    message: String,
    #[serde(skip_serializing_if = "Option::is_none")]
    message_cbor_b64: Option<String>,
    occurred_at: String,
}

#[derive(Debug, Serialize)]
struct WorldResponse {
    ok: bool,
    room: String,
    message: String,
    endpoint_id: String,
    latest_event_sequence: u64,
    broadcasted: bool,
    events: Vec<RoomEvent>,
    /// Handle assigned to the sender after Enter (empty for other request types).
    #[serde(default)]
    handle: String,
    /// Whispers queued for the requesting DID; drained on delivery.
    #[serde(default)]
    pending_whispers: Vec<RoomEvent>,
}

#[derive(Clone, Debug)]
struct WorldProtocol {
    world: Arc<World>,
    endpoint_id: String,
    kubo_url: String,
    did_cache: Arc<RwLock<HashMap<String, CachedDidDocument>>>,
}

#[derive(Clone, Debug)]
struct EntryAcl {
    allow_all: bool,
    allowed_dids: HashSet<String>,
    source: String,
}

#[derive(Debug)]
pub struct World {
    rooms: Arc<RwLock<HashMap<String, Room>>>,
    events: Arc<RwLock<VecDeque<String>>>,
    room_events: Arc<RwLock<HashMap<String, VecDeque<RoomEvent>>>>,
    next_room_event_sequence: Arc<RwLock<u64>>,
    entry_acl: EntryAcl,
    /// handle (string) → root DID.  Prevents two different DIDs sharing a handle.
    handle_to_did: Arc<RwLock<HashMap<String, String>>>,
    /// root DID → assigned handle.  Lets the same DID re-enter with the same handle.
    did_to_handle: Arc<RwLock<HashMap<String, String>>>,
    /// Per-DID whisper queue (root DID → events).  Drained on delivery.
    whisper_queues: Arc<RwLock<HashMap<String, VecDeque<RoomEvent>>>>,
    /// Actor runtime key material loaded from sealed actor bundles.
    actor_secrets: Arc<RwLock<HashMap<String, RuntimeActorSecret>>>,
    /// World owner root DID. Set from config or via @@claim.
    owner_did: Arc<RwLock<Option<String>>>,
}

#[derive(Clone, Debug)]
struct RuntimeActorSecret {
    signing_key: [u8; 32],
    encryption_key: [u8; 32],
}

impl World {
    pub(crate) fn new(entry_acl: EntryAcl) -> Self {
        Self {
            rooms: Arc::new(RwLock::new(HashMap::new())),
            events: Arc::new(RwLock::new(VecDeque::with_capacity(MAX_EVENTS))),
            room_events: Arc::new(RwLock::new(HashMap::new())),
            next_room_event_sequence: Arc::new(RwLock::new(0)),
            entry_acl,
            handle_to_did: Arc::new(RwLock::new(HashMap::new())),
            did_to_handle: Arc::new(RwLock::new(HashMap::new())),
            whisper_queues: Arc::new(RwLock::new(HashMap::new())),
            actor_secrets: Arc::new(RwLock::new(HashMap::new())),
            owner_did: Arc::new(RwLock::new(None)),
        }
    }

    pub(crate) async fn install_actor_secrets(
        &self,
        bundles: &HashMap<String, ActorSecretBundle>,
    ) -> Result<()> {
        let mut decoded = HashMap::new();
        for (actor_id, bundle) in bundles {
            let signing_raw = B64
                .decode(&bundle.secrets.signing_key_b64)
                .map_err(|e| anyhow!("invalid signing key for {}: {}", actor_id, e))?;
            let encryption_raw = B64
                .decode(&bundle.secrets.encryption_key_b64)
                .map_err(|e| anyhow!("invalid encryption key for {}: {}", actor_id, e))?;

            let signing_key: [u8; 32] = signing_raw
                .as_slice()
                .try_into()
                .map_err(|_| anyhow!("signing key for {} must be 32 bytes", actor_id))?;
            let encryption_key: [u8; 32] = encryption_raw
                .as_slice()
                .try_into()
                .map_err(|_| anyhow!("encryption key for {} must be 32 bytes", actor_id))?;

            decoded.insert(
                actor_id.clone(),
                RuntimeActorSecret {
                    signing_key,
                    encryption_key,
                },
            );
        }

        let mut slots = self.actor_secrets.write().await;
        *slots = decoded;
        Ok(())
    }

    pub(crate) async fn actor_secret_count(&self) -> usize {
        self.actor_secrets.read().await.len()
    }

    pub(crate) async fn actor_secret_fingerprint(&self, actor_id: &str) -> Option<String> {
        let slots = self.actor_secrets.read().await;
        let key = slots.get(actor_id)?;
        let mut fp = [0u8; 8];
        fp.copy_from_slice(&key.signing_key[..8]);
        let mut fp2 = [0u8; 8];
        fp2.copy_from_slice(&key.encryption_key[..8]);
        Some(format!("{}:{}", B64.encode(fp), B64.encode(fp2)))
    }

    pub fn can_enter(&self, did: &Did) -> bool {
        if self.entry_acl.allow_all {
            return true;
        }

        self.entry_acl.allowed_dids.contains(&did.without_fragment().id())
    }

    pub fn entry_acl_source(&self) -> &str {
        &self.entry_acl.source
    }

    pub async fn create_room(&self, name: String) -> Result<()> {
        let mut rooms = self.rooms.write().await;
        if rooms.contains_key(&name) {
            return Err(anyhow!("Room {} already exists", name));
        }

        rooms.insert(name.clone(), Room::new(name.clone()));
        drop(rooms);

        let mut room_events = self.room_events.write().await;
        room_events.insert(name.clone(), VecDeque::with_capacity(MAX_EVENTS));
        drop(room_events);

        self.record_event(format!("room created: {name}")).await;
        Ok(())
    }

    pub(crate) async fn join_room(
        &self,
        room_name: &str,
        req: AvatarRequest,
        preferred_handle: Option<String>,
    ) -> Result<String> {
        let mut rooms = self.rooms.write().await;
        let room = rooms
            .get_mut(room_name)
            .ok_or_else(|| anyhow!("Room {} not found", room_name))?;

        let did_root = req.did.without_fragment().id();

        // Check room-level ACL.
        if !room.acl.can_enter(&did_root) {
            return Err(anyhow!("room ACL denied entry for {}", did_root));
        }

        // Same DID already present? Update endpoint and return existing handle.
        if let Some(existing) = room.avatars.get(&req.inbox) {
            if existing.agent_did == req.did {
                info!("[{}] @{} already present ({:?})", room_name, req.inbox, req.did);
                let handle = req.inbox.clone();
                return Ok(handle);
            }
        }

        let avatar = Avatar::new(req.inbox.clone(), req.did.clone(), req.agent_endpoint.clone());
        room.add_avatar(avatar);
        drop(rooms);

        // Resolve and register handle.
        let handle = self.register_handle(&did_root, preferred_handle, &req.inbox).await;

        info!("[{}] @{} joined ({:?}) from {}", room_name, handle, req.did, req.agent_endpoint);
        self.record_event(format!(
            "[{room_name}] @{} joined with {} from {}",
            handle,
            req.did.id(),
            req.agent_endpoint
        ))
        .await;
        self.record_room_event(
            room_name,
            "system",
            Some(handle.clone()),
            Some(did_root.clone()),
            Some(req.agent_endpoint.clone()),
            format!("{} entered {}", handle, room_name),
        )
        .await;
        Ok(handle)
    }

    /// Assign or recover a world-unique handle for `did_root`.
    /// The preferred_handle (from the client) or inbox fragment is the starting candidate.
    /// On collision with a different DID, appends the last 4 characters of the DID root.
    async fn register_handle(
        &self,
        did_root: &str,
        preferred: Option<String>,
        fragment: &str,
    ) -> String {
        // Same DID already has a handle? Return it.
        {
            let d2h = self.did_to_handle.read().await;
            if let Some(h) = d2h.get(did_root) {
                return h.clone();
            }
        }

        let candidate = preferred
            .filter(|h| !h.trim().is_empty())
            .unwrap_or_else(|| fragment.to_string());
        let candidate = candidate.trim().to_string();

        let handle = {
            let h2d = self.handle_to_did.read().await;
            if let Some(owner) = h2d.get(&candidate) {
                if owner == did_root {
                    candidate
                } else {
                    // Collision: disambiguate with last 4 chars of the DID root.
                    let suffix = if did_root.len() >= 4 { &did_root[did_root.len() - 4..] } else { did_root };
                    format!("{}_{}", candidate, suffix)
                }
            } else {
                candidate
            }
        };

        let mut h2d = self.handle_to_did.write().await;
        let mut d2h = self.did_to_handle.write().await;
        h2d.insert(handle.clone(), did_root.to_string());
        d2h.insert(did_root.to_string(), handle.clone());
        handle
    }

    /// Look up the handle for a root DID; falls back to the DID root id itself.
    pub(crate) async fn resolve_handle(&self, did_root: &str) -> String {
        let d2h = self.did_to_handle.read().await;
        d2h.get(did_root).cloned().unwrap_or_else(|| did_root.to_string())
    }

    /// Broadcast a signed chat message to room event log.
    pub async fn send_chat(
        &self,
        room_name: &str,
        sender_handle: &str,
        sender_did_root: &str,
        message_cbor: Vec<u8>,
    ) -> Result<()> {
        let rooms = self.rooms.read().await;
        let room = rooms
            .get(room_name)
            .ok_or_else(|| anyhow!("Room {} not found", room_name))?;

        // Sender must be present in room.
        if !room.avatars.contains_key(sender_handle) {
            return Err(anyhow!(
                "sender @{} is not in room {} — enter first",
                sender_handle,
                room_name
            ));
        }
        drop(rooms);

        let cbor_b64 = B64.encode(&message_cbor);
        info!("[{}] {}: <chat>", room_name, sender_handle);
        self.record_event(format!("[{room_name}] {sender_handle}: <chat>")).await;

        // Build the room event directly so message_cbor_b64 is populated correctly.
        let mut next_sequence = self.next_room_event_sequence.write().await;
        *next_sequence += 1;
        let sequence = *next_sequence;
        drop(next_sequence);

        let entry = RoomEvent {
            sequence,
            room: room_name.to_string(),
            kind: "chat".to_string(),
            sender: Some(sender_handle.to_string()),
            sender_did: Some(sender_did_root.to_string()),
            sender_endpoint: None,
            message: String::new(),
            message_cbor_b64: Some(cbor_b64),
            occurred_at: Utc::now().to_rfc3339(),
        };

        let mut room_events = self.room_events.write().await;
        let events = room_events
            .entry(room_name.to_string())
            .or_insert_with(|| VecDeque::with_capacity(MAX_EVENTS));
        if events.len() >= MAX_EVENTS {
            events.pop_front();
        }
        events.push_back(entry);
        Ok(())
    }

    /// Store a whisper in the recipient's private queue for delivery on their next poll.
    pub async fn queue_whisper(
        &self,
        recipient_did_root: &str,
        sender_handle: &str,
        sender_did_root: &str,
        message_cbor: Vec<u8>,
    ) {
        let cbor_b64 = B64.encode(&message_cbor);
        let mut next_sequence = self.next_room_event_sequence.write().await;
        *next_sequence += 1;
        let sequence = *next_sequence;
        drop(next_sequence);

        let entry = RoomEvent {
            sequence,
            room: String::new(),
            kind: "whisper".to_string(),
            sender: Some(sender_handle.to_string()),
            sender_did: Some(sender_did_root.to_string()),
            sender_endpoint: None,
            message: String::new(),
            message_cbor_b64: Some(cbor_b64),
            occurred_at: Utc::now().to_rfc3339(),
        };

        let mut queues = self.whisper_queues.write().await;
        let queue = queues.entry(recipient_did_root.to_string()).or_insert_with(VecDeque::new);
        if queue.len() >= MAX_EVENTS {
            queue.pop_front();
        }
        queue.push_back(entry);

        info!("Whisper queued for {} from {}", recipient_did_root, sender_handle);
    }

    /// Drain and return all pending whispers for `did_root`.
    pub(crate) async fn drain_pending_whispers(&self, did_root: &str) -> Vec<RoomEvent> {
        let mut queues = self.whisper_queues.write().await;
        let queue = queues.entry(did_root.to_string()).or_insert_with(VecDeque::new);
        queue.drain(..).collect()
    }

    pub async fn leave_room(&self, room_name: &str, actor_name: &str) -> Result<()> {
        let mut rooms = self.rooms.write().await;
        let room = rooms
            .get_mut(room_name)
            .ok_or_else(|| anyhow!("Room {} not found", room_name))?;

        room.remove_avatar(actor_name);
        drop(rooms);

        info!("[{}] {} left", room_name, actor_name);
        self.record_event(format!("[{room_name}] {actor_name} left")).await;
        self.record_room_event(
            room_name,
            "system",
            Some(actor_name.to_string()),
            None,
            None,
            format!("{} left {}", actor_name, room_name),
        )
        .await;
        Ok(())
    }

    pub async fn send_message(
        &self,
        room_name: &str,
        from: &str,
        from_did: &Did,
        envelope: MessageEnvelope,
    ) -> Result<(String, bool)> {
        {
            let rooms = self.rooms.read().await;
            let room = rooms
                .get(room_name)
                .ok_or_else(|| anyhow!("Room {} not found", room_name))?;

            let Some(avatar) = room.avatars.get(from) else {
                return Err(anyhow!("unknown avatar @{} in room {}", from, room_name));
            };
            if avatar.agent_did != from_did.without_fragment() {
                return Err(anyhow!(
                    "sender DID mismatch for @{} in room {}",
                    from,
                    room_name
                ));
            }
        }

        let (response, broadcasted) = match envelope {
            MessageEnvelope::Chatter { text } => {
                let speech = normalize_spoken_text(&text);
                info!("[{}] {}: {}", room_name, from, speech);
                self.record_event(format!("[{room_name}] {from}: {speech}")).await;
                let rendered = format!("{}: {}", from, speech);
                self.record_room_event(room_name, "speech", Some(from.to_string()), None, None, rendered.clone())
                    .await;
                (rendered, true)
            }
            MessageEnvelope::RoomCommand { command } => {
                let response = self.room_command(room_name, &command, from).await;
                info!("[{}] {} -> @here: {} -> {}", room_name, from, command, response);
                self.record_event(format!("[{room_name}] {from} -> @here: {command} => {}", response))
                    .await;
                (response, false)
            }
            MessageEnvelope::ActorCommand { target, command } => {
                let broadcasted = matches!(command, ActorCommand::Say { .. });
                let response = self
                    .handle_actor_command(room_name, from, &target, command)
                    .await;
                info!("[{}] {} -> @{} -> {}", room_name, from, target, response);
                self.record_event(format!(
                    "[{room_name}] {from} -> @{target} => {}",
                    response.replace('\n', " ")
                ))
                .await;
                if broadcasted {
                    self.record_room_event(room_name, "speech", Some(from.to_string()), None, None, response.clone())
                        .await;
                }
                (response, broadcasted)
            }
        };

        Ok((response, broadcasted))
    }

    async fn room_events_since(&self, room_name: &str, since_sequence: u64) -> Result<(Vec<RoomEvent>, u64)> {
        let room_events = self.room_events.read().await;
        let events = room_events
            .get(room_name)
            .ok_or_else(|| anyhow!("Room {} not found", room_name))?;

        let items = events
            .iter()
            .filter(|event| event.sequence > since_sequence)
            .cloned()
            .collect::<Vec<_>>();
        let latest = events.back().map(|event| event.sequence).unwrap_or(since_sequence);
        Ok((items, latest))
    }

    async fn latest_room_event_sequence(&self, room_name: &str) -> Result<u64> {
        let room_events = self.room_events.read().await;
        let latest = room_events
            .get(room_name)
            .ok_or_else(|| anyhow!("Room {} not found", room_name))?
            .back()
            .map(|event| event.sequence)
            .unwrap_or(0);
        Ok(latest)
    }

    pub async fn snapshot(&self) -> WorldSnapshot {
        let rooms = self.rooms.read().await;
        let mut room_items = rooms
            .values()
            .map(|room| {
                let mut avatars = room
                    .avatars
                    .values()
                    .map(|avatar| AvatarSnapshot {
                        inbox: avatar.inbox.clone(),
                        agent_did: avatar.agent_did.id(),
                        agent_endpoint: avatar.agent_endpoint.clone(),
                        owner: avatar.owner.clone(),
                        description: avatar.description_or_default("en"),
                        acl: avatar.acl.summary(),
                        joined_at: format_system_time(avatar.joined_at),
                    })
                    .collect::<Vec<_>>();
                avatars.sort_by(|left, right| left.inbox.cmp(&right.inbox));

                RoomSnapshot {
                    name: room.name.clone(),
                    avatars,
                }
            })
            .collect::<Vec<_>>();
        room_items.sort_by(|left, right| left.name.cmp(&right.name));
        drop(rooms);

        let events = self.events.read().await.iter().cloned().collect();

        WorldSnapshot {
            rooms: room_items,
            recent_events: events,
        }
    }

    async fn handle_actor_command(
        &self,
        room_name: &str,
        from: &str,
        target: &str,
        command: ActorCommand,
    ) -> String {
        match target {
            "here" | "room" => {
                let room_cmd = match command {
                    ActorCommand::Say { payload } => payload,
                    ActorCommand::Raw { command } => command,
                };
                self.room_command(room_name, &room_cmd, from).await
            }
            "world" => {
                let cmd = match command {
                    ActorCommand::Say { payload } => payload,
                    ActorCommand::Raw { command } => command,
                };
                self.handle_world_command(room_name, from, &cmd).await
            }
            "avatar" => self.handle_avatar_command(room_name, from, command).await,
            _ => {
                let rooms = self.rooms.read().await;
                let Some(room) = rooms.get(room_name) else {
                    return format!("@here room '{}' not found", room_name);
                };
                let actor_exists = room.avatars.contains_key(target) || target == from;
                if !actor_exists {
                    warn!("[{}] Unknown actor: @{}", room_name, target);
                    return format!("Unknown actor: @{}", target);
                }

                match command {
                    ActorCommand::Say { payload } => {
                        let speech = normalize_spoken_text(&payload);
                        format!("@{} says to @{}: {}", from, target, speech)
                    }
                    ActorCommand::Raw { command } => {
                        format!("@{} is here. Try '@{} say \"...\"'. (got: {})", target, target, command)
                    }
                }
            }
        }
    }

    async fn handle_avatar_command(&self, room_name: &str, from: &str, command: ActorCommand) -> String {
        match command {
            ActorCommand::Say { payload } => {
                // ' / say: broadcast speech to the room, formatted identically to Chatter.
                let speech = normalize_spoken_text(&payload);
                format!("{}: {}", from, speech)
            }
            ActorCommand::Raw { command } => {
                let trimmed = command.trim();

                // Movement: `go <direction>` or bare direction name.
                let direction = trimmed
                    .strip_prefix("go ")
                    .map(str::trim)
                    .unwrap_or(trimmed);

                let move_target = {
                    let rooms = self.rooms.read().await;
                    rooms.get(room_name).and_then(|room| {
                        room.exits
                            .iter()
                            .find(|e| e.matches(direction))
                            .map(|exit| (exit.locked, exit.to.clone(), exit.name.clone()))
                    })
                };

                if let Some((locked, destination, exit_name)) = move_target {
                    if locked {
                        return format!("The way {} is locked.", exit_name);
                    }
                    let mut rooms = self.rooms.write().await;
                    let avatar = rooms
                        .get_mut(room_name)
                        .and_then(|r| r.avatars.remove(from));
                    if let Some(avatar) = avatar {
                        if rooms.contains_key(&destination) {
                            rooms.get_mut(&destination).unwrap().add_avatar(avatar);
                            return format!("{} goes {}.", from, exit_name);
                        } else {
                            // Destination vanished — put avatar back.
                            if let Some(src) = rooms.get_mut(room_name) {
                                src.add_avatar(avatar);
                            }
                            return format!("Destination '{}' no longer exists.", destination);
                        }
                    }
                    return format!("{} goes {}.", from, exit_name);
                }

                if let Some(rest) = trimmed.strip_prefix("describe ") {
                    let description = normalize_spoken_text(rest).trim().to_string();
                    if description.is_empty() {
                        return "@avatar describe requires text".to_string();
                    }

                    let mut rooms = self.rooms.write().await;
                    let Some(room) = rooms.get_mut(room_name) else {
                        return format!("@here room '{}' not found", room_name);
                    };
                    let Some(avatar) = room.avatars.get_mut(from) else {
                        return format!("@avatar '{}' not found", from);
                    };

                    avatar.set_description("en", description.clone());
                    avatar.set_description("nb", description.clone());
                    return format!("@avatar owner={} desc={}", avatar.owner, description);
                }

                if trimmed.eq_ignore_ascii_case("show") || trimmed.eq_ignore_ascii_case("who") {
                    let rooms = self.rooms.read().await;
                    let Some(room) = rooms.get(room_name) else {
                        return format!("@here room '{}' not found", room_name);
                    };
                    let Some(avatar) = room.avatars.get(from) else {
                        return format!("@avatar '{}' not found", from);
                    };
                    return format!(
                        "@avatar owner={} desc={} acl={}",
                        avatar.owner,
                        avatar.description_or_default("en"),
                        avatar.acl.summary()
                    );
                }

                "@avatar commands: describe \"...\" | show".to_string()
            }
        }
    }

        async fn handle_world_command(&self, room_name: &str, from: &str, command: &str) -> String {
            let normalized = command.trim();

            if normalized.is_empty() || normalized.eq_ignore_ascii_case("help") {
                return "@world commands: help | claim | dig <direction> [to <#dest>]".to_string();
            }

            // Resolve caller's root DID.
            let caller_root_did = self
                .did_to_handle
                .read()
                .await
                .iter()
                .find(|(_, handle)| *handle == from)
                .map(|(did, _)| did.clone());

            // @@claim — set world owner to caller's root DID if unclaimed.
            if normalized.eq_ignore_ascii_case("claim") {
                let mut owner = self.owner_did.write().await;
                if owner.is_some() {
                    return "@world already has an owner.".to_string();
                }
                let Some(did) = caller_root_did else {
                    return "@world cannot identify your DID.".to_string();
                };
                *owner = Some(did.clone());
                info!("World claimed by {}", did);
                // TODO: persist to config file.
                return format!("@world claimed by {}", did);
            }

            // All remaining commands require world-owner privilege.
            let owner_did = self.owner_did.read().await.clone();
            let is_owner = owner_did
                .as_deref()
                .zip(caller_root_did.as_deref())
                .map(|(owner, caller)| owner == caller)
                .unwrap_or(false);

            if !is_owner {
                return "@world only the world owner can run that command.".to_string();
            }

            // @@dig <direction> [to <#dest>]
            let mut parts = normalized.splitn(2, char::is_whitespace);
            let verb = parts.next().unwrap_or_default().to_ascii_lowercase();
            let arg = parts.next().unwrap_or_default().trim().to_string();

            if verb == "dig" {
                if arg.is_empty() {
                    return "@world usage: @@dig <direction> [to <#dest>]".to_string();
                }

                let (exit_name, destination) = if let Some((dir, dest)) = arg.split_once(" to ") {
                    let dest_clean = dest.trim().trim_start_matches('#').to_string();
                    (dir.trim().to_string(), if dest_clean.is_empty() { None } else { Some(dest_clean) })
                } else {
                    (arg.clone(), None)
                };

                let dest_name = destination
                    .clone()
                    .unwrap_or_else(|| format!("{}-{}", room_name, exit_name));
                let exit_id = format!("{}-{}", room_name, exit_name);

                let mut rooms = self.rooms.write().await;
                rooms
                    .entry(dest_name.clone())
                    .or_insert_with(|| crate::room::Room::new(dest_name.clone()));
                if let Some(room) = rooms.get_mut(room_name) {
                    if !room.exits.iter().any(|e| e.matches(&exit_name)) {
                        room.exits.push(ma_actor::ExitData::new(exit_id, exit_name.clone(), dest_name.clone()));
                    }
                }
                return format!("@world exit '{}' dug from '{}' → '{}'", exit_name, room_name, dest_name);
            }

            format!("@world unknown command: {}", normalized)
        }

    async fn room_command(&self, room_name: &str, command: &str, from: &str) -> String {
        let caller_root_did = self
            .did_to_handle
            .read()
            .await
            .iter()
            .find(|(_, handle)| *handle == from)
            .map(|(did_root, _)| did_root.clone());

        let (room_exists, avatars, acl_owner, acl_summary) = {
            let rooms = self.rooms.read().await;
            if let Some(room) = rooms.get(room_name) {
                (
                    true,
                    room.avatars.keys().cloned().collect::<Vec<_>>(),
                    room.acl.owner.clone(),
                    room.acl.summary(),
                )
            } else {
                (false, Vec::new(), None, "(none)".to_string())
            }
        };

        let ctx = RoomActorContext {
            room_name,
            room_exists,
            avatars,
            acl_owner_did: acl_owner.as_deref(),
            acl_summary: &acl_summary,
            caller_root_did: caller_root_did.as_deref(),
        };

        let decision = execute_room_actor_command(command, &ctx);
        let response = decision.response.clone();

        match decision.action {
            RoomActorAction::None => {}
            RoomActorAction::Invite { did } => {
                let mut rooms = self.rooms.write().await;
                if let Some(room) = rooms.get_mut(room_name) {
                    room.acl.allow.insert(did.clone());
                    room.acl.deny.remove(&did);
                }
            }
            RoomActorAction::Deny { did } => {
                let mut rooms = self.rooms.write().await;
                if let Some(room) = rooms.get_mut(room_name) {
                    room.acl.deny.insert(did.clone());
                    room.acl.allow.remove(&did);
                    room.avatars.retain(|_, av| av.agent_did.without_fragment().id() != did);
                }
            }
            RoomActorAction::Kick { handle } => {
                let mut rooms = self.rooms.write().await;
                if let Some(room) = rooms.get_mut(room_name) {
                    room.avatars.remove(&handle);
                }
            }
            RoomActorAction::Dig { exit_name, destination } => {
                let new_room_name = destination
                    .unwrap_or_else(|| format!("{}-{}", room_name, exit_name));
                let exit_id = format!("{}-{}", room_name, exit_name);
                let mut rooms = self.rooms.write().await;
                // Create the destination room if it doesn't exist yet.
                rooms
                    .entry(new_room_name.clone())
                    .or_insert_with(|| crate::room::Room::new(new_room_name.clone()));
                // Add the outbound exit to the source room.
                if let Some(room) = rooms.get_mut(room_name) {
                    let already_exists = room.exits.iter().any(|e| e.matches(&exit_name));
                    if !already_exists {
                        room.exits.push(ExitData::new(exit_id, exit_name.clone(), new_room_name));
                    }
                }
            }
        }

        response
    }

    async fn record_event(&self, event: String) {
        let entry = format!("{} {}", Utc::now().to_rfc3339(), event);
        let mut events = self.events.write().await;
        if events.len() >= MAX_EVENTS {
            events.pop_front();
        }
        events.push_back(entry);
    }

    async fn record_room_event(
        &self,
        room_name: &str,
        kind: &str,
        sender: Option<String>,
        sender_did: Option<String>,
        sender_endpoint: Option<String>,
        message: String,
    ) -> u64 {
        let mut next_sequence = self.next_room_event_sequence.write().await;
        *next_sequence += 1;
        let sequence = *next_sequence;
        drop(next_sequence);

        let entry = RoomEvent {
            sequence,
            room: room_name.to_string(),
            kind: kind.to_string(),
            sender,
            sender_did,
            sender_endpoint,
            message,
            message_cbor_b64: None,
            occurred_at: Utc::now().to_rfc3339(),
        };

        let mut room_events = self.room_events.write().await;
        let events = room_events
            .entry(room_name.to_string())
            .or_insert_with(|| VecDeque::with_capacity(MAX_EVENTS));
        if events.len() >= MAX_EVENTS {
            events.pop_front();
        }
        events.push_back(entry);
        sequence
    }
}

impl WorldProtocol {
    fn content_type_matches(actual: &str, canonical: &str, legacy: &str) -> bool {
        actual == canonical || actual == legacy
    }

    async fn process_request(&self, request: WorldRequest, agent_endpoint: String) -> WorldResponse {
        match self.handle_request(request, agent_endpoint).await {
            Ok(resp) => resp,
            Err(err) => {
                warn!("request error: {}", err);
                WorldResponse {
                    ok: false,
                    room: String::new(),
                    message: err.to_string(),
                    endpoint_id: self.endpoint_id.clone(),
                    latest_event_sequence: 0,
                    broadcasted: false,
                    events: Vec::new(),
                    handle: String::new(),
                    pending_whispers: Vec::new(),
                }
            }
        }
    }

    async fn get_sender_document(&self, sender_root: &Did) -> Result<(Document, bool)> {
        let cache_key = sender_root.id();

        {
            let cache = self.did_cache.read().await;
            if let Some(cached) = cache.get(&cache_key) {
                if cached.fetched_at.elapsed() <= DID_CACHE_TTL {
                    return Ok((cached.document.clone(), false));
                }
            }
        }

        let fetched = kubo::fetch_did_document(&self.kubo_url, sender_root).await?;

        let mut cache = self.did_cache.write().await;
        cache.insert(
            cache_key,
            CachedDidDocument {
                document: fetched.clone(),
                fetched_at: Instant::now(),
            },
        );

        Ok((fetched, true))
    }

    async fn verify_message(&self, message_cbor: Vec<u8>) -> Result<(Message, Did, Document)> {
        let message = Message::from_cbor(&message_cbor)?;
        let sender_did = Did::try_from(message.from.as_str())?;
        let sender_root = sender_did.without_fragment();

        let t0 = std::time::Instant::now();
        let (sender_document, fetched_from_kubo) = self.get_sender_document(&sender_root).await
            .map_err(|e| {
                warn!("DID doc fetch failed for {} after {:?}: {}", sender_root.id(), t0.elapsed(), e);
                e
            })?;
        if fetched_from_kubo {
            info!("DID doc for {} fetched via Kubo in {:?}", sender_root.id(), t0.elapsed());
        } else {
            debug!("DID doc for {} served from cache in {:?}", sender_root.id(), t0.elapsed());
        }

        message.verify_with_document(&sender_document)?;
        Ok((message, sender_did, sender_document))
    }

    async fn handle_request(&self, request: WorldRequest, agent_endpoint: String) -> Result<WorldResponse> {
        match request {
            WorldRequest::Signed { message_cbor } => {
                // Legacy command path.
                let (message, sender_did, sender_document) = self.verify_message(message_cbor).await?;
                if !Self::content_type_matches(&message.content_type, CONTENT_TYPE_COMMAND, "application/x.ma.command") {
                    return Err(anyhow!("unsupported content_type: {}", message.content_type));
                }
                let command: WorldCommand = serde_json::from_slice(&message.content)
                    .map_err(|err| anyhow!("invalid command payload: {}", err))?;
                let sender_root = sender_did.without_fragment().id();
                let pending = self.world.drain_pending_whispers(&sender_root).await;
                let mut resp = self.handle_command(command, &message, &sender_did, sender_document, agent_endpoint, &sender_root).await?;
                resp.pending_whispers = pending;
                Ok(resp)
            }

            WorldRequest::Chat { room, message_cbor } => {
                let (message, sender_did, _) = self.verify_message(message_cbor.clone()).await?;
                if !Self::content_type_matches(&message.content_type, CONTENT_TYPE_CHAT, "application/x.ma.chat") {
                    return Err(anyhow!("expected application/x-ma-chat, got {}", message.content_type));
                }
                let sender_root = sender_did.without_fragment().id();
                let handle = self.world.resolve_handle(&sender_root).await;
                if handle == sender_root {
                    return Err(anyhow!("not registered in room — enter first"));
                }
                self.world.send_chat(&room, &handle, &sender_root, message_cbor).await?;
                let latest_event_sequence = self.world.latest_room_event_sequence(&room).await?;
                let pending = self.world.drain_pending_whispers(&sender_root).await;
                Ok(WorldResponse {
                    ok: true,
                    room,
                    message: String::new(),
                    endpoint_id: self.endpoint_id.clone(),
                    latest_event_sequence,
                    broadcasted: true,
                    events: Vec::new(),
                    handle,
                    pending_whispers: pending,
                })
            }

            WorldRequest::Whisper { message_cbor } => {
                let (message, sender_did, _) = self.verify_message(message_cbor.clone()).await?;
                if !Self::content_type_matches(&message.content_type, CONTENT_TYPE_WHISPER, "application/x.ma.whisper") {
                    return Err(anyhow!("expected application/x-ma-whisper, got {}", message.content_type));
                }
                let sender_root = sender_did.without_fragment().id();
                let sender_handle = self.world.resolve_handle(&sender_root).await;
                let recipient_did = Did::try_from(message.to.as_str())?;
                let recipient_root = recipient_did.without_fragment().id();
                self.world.queue_whisper(&recipient_root, &sender_handle, &sender_root, message_cbor).await;
                let pending = self.world.drain_pending_whispers(&sender_root).await;
                Ok(WorldResponse {
                    ok: true,
                    room: String::new(),
                    message: "whisper queued".to_string(),
                    endpoint_id: self.endpoint_id.clone(),
                    latest_event_sequence: 0,
                    broadcasted: false,
                    events: Vec::new(),
                    handle: sender_handle,
                    pending_whispers: pending,
                })
            }
        }
    }

    async fn handle_command(
        &self,
        command: WorldCommand,
        _message: &Message,
        sender_did: &Did,
        _sender_document: Document,
        agent_endpoint: String,
        sender_root: &str,
    ) -> Result<WorldResponse> {
        match command {
            WorldCommand::Enter { room, preferred_handle } => {
                let room = room.unwrap_or_else(|| DEFAULT_ROOM.to_string());
                let root_did = sender_did.without_fragment();
                if !self.world.can_enter(&root_did) {
                    return Err(anyhow!("enter denied by ACL for {}", root_did.id()));
                }
                let inbox = resolve_avatar_inbox(sender_did)?;
                let avatar_req = AvatarRequest {
                    inbox,
                    did: root_did,
                    agent_endpoint,
                };
                let handle = self.world.join_room(&room, avatar_req, preferred_handle).await?;
                let latest_event_sequence = self.world.latest_room_event_sequence(&room).await?;
                let pending = self.world.drain_pending_whispers(sender_root).await;
                Ok(WorldResponse {
                    ok: true,
                    room: room.clone(),
                    message: format!("entered {room}"),
                    endpoint_id: self.endpoint_id.clone(),
                    latest_event_sequence,
                    broadcasted: false,
                    events: Vec::new(),
                    handle,
                    pending_whispers: pending,
                })
            }
            WorldCommand::Message { room, envelope } => {
                let actor_name = resolve_avatar_inbox(sender_did)?;
                let (message, broadcasted) = self
                    .world
                    .send_message(&room, &actor_name, sender_did, envelope)
                    .await?;
                let latest_event_sequence = self.world.latest_room_event_sequence(&room).await?;
                let pending = self.world.drain_pending_whispers(sender_root).await;
                Ok(WorldResponse {
                    ok: true,
                    room,
                    message,
                    endpoint_id: self.endpoint_id.clone(),
                    latest_event_sequence,
                    broadcasted,
                    events: Vec::new(),
                    handle: String::new(),
                    pending_whispers: pending,
                })
            }
            WorldCommand::RoomEvents { room, since_sequence } => {
                let (events, latest_event_sequence) = self.world.room_events_since(&room, since_sequence).await?;
                let pending = self.world.drain_pending_whispers(sender_root).await;
                Ok(WorldResponse {
                    ok: true,
                    room,
                    message: String::new(),
                    endpoint_id: self.endpoint_id.clone(),
                    latest_event_sequence,
                    broadcasted: false,
                    events,
                    handle: String::new(),
                    pending_whispers: pending,
                })
            }
        }
    }

}

impl ProtocolHandler for WorldProtocol {
    /// One task runs per connection and serves a single long-lived bi-stream with framed messages.
    async fn accept(&self, connection: Connection) -> Result<(), AcceptError> {
        let agent_endpoint = connection.remote_id().to_string();
        self.world
            .record_event(format!("connection accepted from {}", agent_endpoint))
            .await;
        let (mut send, mut recv) = connection.accept_bi().await?;

        loop {
            let frame_len = match recv.read_u32().await {
                Ok(n) => n as usize,
                Err(err) if err.kind() == std::io::ErrorKind::UnexpectedEof => break,
                Err(err) => return Err(AcceptError::from_err(err)),
            };
            if frame_len > 256 * 1024 {
                return Err(AcceptError::from_err(std::io::Error::new(
                    std::io::ErrorKind::InvalidData,
                    format!("request frame too large: {}", frame_len),
                )));
            }

            let mut bytes = vec![0u8; frame_len];
            recv.read_exact(&mut bytes).await.map_err(AcceptError::from_err)?;

            let response = match serde_json::from_slice::<WorldRequest>(&bytes) {
                Ok(request) => self.process_request(request, agent_endpoint.clone()).await,
                Err(err) => WorldResponse {
                    ok: false,
                    room: String::new(),
                    message: format!("invalid request JSON: {}", err),
                    endpoint_id: self.endpoint_id.clone(),
                    latest_event_sequence: 0,
                    broadcasted: false,
                    events: Vec::new(),
                    handle: String::new(),
                    pending_whispers: Vec::new(),
                },
            };
            let payload = serde_json::to_vec(&response).map_err(AcceptError::from_err)?;

            send.write_u32(payload.len() as u32)
                .await
                .map_err(AcceptError::from_err)?;
            send.write_all(&payload).await.map_err(AcceptError::from_err)?;
            send.flush().await.map_err(AcceptError::from_err)?;
        }

        let _ = send.finish();
        Ok(())
    }
}

fn print_cli_help() {
    println!("ma-world");
    println!();
    println!("Usage:");
    println!("  ma-world [COMMAND] [OPTIONS]");
    println!();
    println!("Commands:");
    println!("  run                 Start ma-world server (default when no command is provided)");
    println!("  print-effective-config  Show resolved config values and their sources");
    println!("  print-config        Print synthesized config (CLI/env/config/default)");
    println!("  init-world          Create a skeleton world layout in world-dir");
    println!("  validate-world      Validate authored world schema files");
    println!("  check-kubo-keys     Verify required Kubo key names exist");
    println!("  ensure-kubo-keys    Create missing required Kubo keys");
    println!("  check-kubo-ipns     Preflight dag/put + IPNS name/publish health check");
    println!("  publish-world       Publish authored world DAG and optional IPNS records");
    println!();
    println!("Global flags:");
    println!("  -h, --help          Show this help text and exit");
    println!("  --config <path>     Override config file path");
    println!();
    println!("publish-world options:");
    println!("  --world-slug <slug>");
    println!("  --world-dir <path>");
    println!("  --skip-ipns");
    println!("  --allow-partial-ipns");
    println!("  --ipns-timeout-ms <ms>");
    println!("  --ipns-retries <n>");
    println!("  --ipns-backoff-ms <ms>");
    println!();
    println!("run options (server mode):");
    println!("  --listen <ip:port>");
    println!("  --world-slug <slug>");
    println!("  --world-dir <path>");
    println!("  --log-level <level>    Log level: trace, debug, info (default), warn, error");
    println!("  --log-file <path>      Write logs to file (appends to existing file)");
    println!();
    println!("init-world options:");
    println!("  --world-slug <slug>");
    println!("  --world-dir <path>");
    println!("  --force");
    println!("  --kubo-url <url>");
    println!();
    println!("print-effective-config options:");
    println!("  --listen <ip:port>");
    println!("  --world-slug <slug>");
    println!("  --world-dir <path>");
    println!("  --kubo-url <url>");
    println!();
    println!("print-config options:");
    println!("  --listen <ip:port>");
    println!("  --world-slug <slug>");
    println!("  --world-dir <path>");
    println!("  --kubo-url <url>");
    println!("  --log-level <level>");
    println!("  --log-file <path>");
    println!();
    println!("Configuration file (world-scoped):");
    println!("  $XDG_CONFIG_HOME/ma/<world-slug>.yaml");
    println!("  or $XDG_CONFIG_HOME/ma/<world-slug>/config.yaml");
    println!("  kubo_api_url (string)         Kubo HTTP API URL (default: http://127.0.0.1:5001)");
    println!("  listen (string)               HTTP status listen socket (default: 127.0.0.1:5002)");
    println!("  world_slug (string)           World slug for 'run' command");
    println!("  world_dir (string)            World directory for 'run' command");
    println!("  log_level (string)            Log level for 'run' command (default: info)");
    println!("  log_file (string)             Log file path for 'run' command");
    println!();
    println!("Environment variables:");
    println!("  MA_KUBO_API_URL               Kubo API URL (overrides config)");
    println!("  MA_LISTEN                     HTTP status listen socket (overrides config)");
    println!("  MA_WORLD_SLUG                 World slug for 'run' command (overrides config)");
    println!("  MA_WORLD_DIR                  World directory for 'run' command (overrides config)");
    println!("  MA_LOG_LEVEL                  Log level for 'run' command (overrides config)");
    println!("  MA_LOG_FILE                   Log file path for 'run' command (overrides config)");
    println!();
    println!("Precedence (highest to lowest): CLI args > env vars > config file > defaults");
}

#[derive(Clone, Debug)]
struct ResolvedWorldIdentity {
    world: InitWorldIdentity,
}

async fn resolve_world_identity_from_kubo(
    kubo_url: &str,
    world_slug: &str,
) -> Result<ResolvedWorldIdentity> {
    let world_key_name = normalize_world_key_name(world_slug);
    let lobby_key_name = format!("{}-lobby", world_key_name);

    let mut keys = list_kubo_keys(kubo_url).await?;
    let has_world = keys.iter().any(|k| k.name == world_key_name);
    let has_lobby = keys.iter().any(|k| k.name == lobby_key_name);

    if !has_world {
        generate_kubo_key(kubo_url, &world_key_name).await?;
    }
    if !has_lobby {
        generate_kubo_key(kubo_url, &lobby_key_name).await?;
    }
    if !has_world || !has_lobby {
        keys = list_kubo_keys(kubo_url).await?;
    }

    let world_ipns = keys
        .iter()
        .find(|k| k.name == world_key_name)
        .map(|k| k.id.clone())
        .ok_or_else(|| anyhow!("missing Kubo key id for '{}': key/list did not return Id", world_key_name))?;

    let lobby_ipns = keys
        .iter()
        .find(|k| k.name == lobby_key_name)
        .map(|k| k.id.clone())
        .ok_or_else(|| anyhow!("missing Kubo key id for '{}': key/list did not return Id", lobby_key_name))?;

    let world_id = format!("did:ma:{}#{}", world_ipns, world_key_name);
    let lobby_id = format!("did:ma:{}#{}", lobby_ipns, lobby_key_name);

    Ok(ResolvedWorldIdentity {
        world: InitWorldIdentity {
            world_ipns_key_name: world_key_name,
            lobby_ipns_key_name: lobby_key_name,
            world_id,
            lobby_id,
        },
    })
}

#[tokio::main]
async fn main() -> Result<()> {
    let raw_args = std::env::args().collect::<Vec<_>>();
    let (args, cli_config_override) = extract_global_config_arg(raw_args)?;
    let mut run_arg_mode = false;
    let mut run_world_slug_override: Option<String> = None;
    let mut run_world_dir_override: Option<PathBuf> = None;
    let mut listen_addr: String = DEFAULT_LISTEN_ADDR.to_string();
    let mut log_level: String = "info".to_string();
    let mut log_file: Option<PathBuf> = None;

    if args.len() >= 2 {
        match args[1].as_str() {
            "-h" | "--help" | "help" => {
                print_cli_help();
                return Ok(());
            }
            "run" => {
                run_arg_mode = true;
                let mut idx = 2usize;
                while idx < args.len() {
                    match args[idx].as_str() {
                        "--world-slug" => {
                            idx += 1;
                            if idx >= args.len() {
                                return Err(anyhow!("missing value for --world-slug"));
                            }
                            run_world_slug_override = Some(args[idx].clone());
                        }
                        "--listen" => {
                            idx += 1;
                            if idx >= args.len() {
                                return Err(anyhow!("missing value for --listen"));
                            }
                            listen_addr = args[idx].clone();
                        }
                        "--world-dir" => {
                            idx += 1;
                            if idx >= args.len() {
                                return Err(anyhow!("missing value for --world-dir"));
                            }
                            run_world_dir_override = Some(PathBuf::from(&args[idx]));
                        }
                        "--log-level" => {
                            idx += 1;
                            if idx >= args.len() {
                                return Err(anyhow!("missing value for --log-level"));
                            }
                            log_level = args[idx].clone();
                        }
                        "--log-file" => {
                            idx += 1;
                            if idx >= args.len() {
                                return Err(anyhow!("missing value for --log-file"));
                            }
                            log_file = Some(PathBuf::from(&args[idx]));
                        }
                        other => {
                            return Err(anyhow!(
                                "unknown argument '{}' for run (supported: --listen, --world-slug, --world-dir, --log-level, --log-file)",
                                other
                            ));
                        }
                    }
                    idx += 1;
                }
            }
            _ => {}
        }
    }

    // Backwards-compatible server mode with top-level flags and no explicit command.
    if !run_arg_mode && args.len() >= 2 && args[1].starts_with('-') {
        run_arg_mode = true;
        let mut idx = 1usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    run_world_slug_override = Some(args[idx].clone());
                }
                "--listen" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --listen"));
                    }
                    listen_addr = args[idx].clone();
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    run_world_dir_override = Some(PathBuf::from(&args[idx]));
                }
                "--log-level" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --log-level"));
                    }
                    log_level = args[idx].clone();
                }
                "--log-file" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --log-file"));
                    }
                    log_file = Some(PathBuf::from(&args[idx]));
                }
                other => {
                    return Err(anyhow!(
                        "unknown top-level argument '{}'. Use 'publish-world' for publish flags like --skip-ipns, or use run/--listen/--world-slug/--world-dir for server mode.",
                        other
                    ));
                }
            }
            idx += 1;
        }
    }

    let bootstrap_world_slug = scan_world_slug_arg(&args)
        .or_else(|| std::env::var("MA_WORLD_SLUG").ok())
        .unwrap_or_else(|| DEFAULT_WORLD_SLUG.to_string());
    let app_config_path = resolve_app_config_path(&bootstrap_world_slug, &cli_config_override);
    let app_config_exists = app_config_path.exists();
    let app_config = load_app_config(&app_config_path)?;
    let default_world_slug = DEFAULT_WORLD_SLUG.to_string();
    let default_kubo_url = app_config
        .kubo_api_url
        .clone()
        .unwrap_or_else(|| DEFAULT_KUBO_API_URL.to_string());

    // Apply config file values for run mode parameters with proper precedence:
    // CLI args > env vars > config file > defaults
    if run_arg_mode {
        // Apply log_level precedence (CLI args already set if provided)
        if listen_addr == DEFAULT_LISTEN_ADDR {
            if let Ok(env_listen) = std::env::var("MA_LISTEN") {
                listen_addr = env_listen;
            } else if let Some(config_listen) = &app_config.listen {
                listen_addr = config_listen.clone();
            }
        }

        // Apply log_level precedence (CLI args already set if provided)
        if log_level == "info" {
            // Still default, check config and env
            if let Ok(env_level) = std::env::var("MA_LOG_LEVEL") {
                log_level = env_level;
            } else if let Some(config_level) = &app_config.log_level {
                log_level = config_level.clone();
            }
        }

        // Apply log_file precedence (CLI args already set if provided)
        if log_file.is_none() {
            if let Ok(env_file) = std::env::var("MA_LOG_FILE") {
                log_file = Some(PathBuf::from(env_file));
            } else if let Some(config_file) = &app_config.log_file {
                log_file = Some(PathBuf::from(config_file));
            }
        }

        // Apply world_slug precedence (CLI args already set if provided)
        if run_world_slug_override.is_none() {
            if let Ok(env_slug) = std::env::var("MA_WORLD_SLUG") {
                run_world_slug_override = Some(env_slug);
            } else if let Some(config_slug) = &app_config.world_slug {
                run_world_slug_override = Some(config_slug.clone());
            }
        }

        // Apply world_dir precedence (CLI args already set if provided)
        if run_world_dir_override.is_none() {
            if let Ok(env_dir) = std::env::var("MA_WORLD_DIR") {
                run_world_dir_override = Some(PathBuf::from(env_dir));
            } else if let Some(config_dir) = &app_config.world_dir {
                run_world_dir_override = Some(PathBuf::from(config_dir));
            }
        }
    }

    if args.len() >= 2 && args[1] == "print-config" {
        let mut cli_listen: Option<String> = None;
        let mut cli_world_slug: Option<String> = None;
        let mut cli_world_dir: Option<PathBuf> = None;
        let mut cli_kubo_url: Option<String> = None;
        let mut cli_log_level: Option<String> = None;
        let mut cli_log_file: Option<String> = None;

        let mut idx = 2usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--listen" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --listen"));
                    }
                    cli_listen = Some(args[idx].clone());
                }
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    cli_world_slug = Some(args[idx].clone());
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    cli_world_dir = Some(PathBuf::from(&args[idx]));
                }
                "--kubo-url" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --kubo-url"));
                    }
                    cli_kubo_url = Some(args[idx].clone());
                }
                "--log-level" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --log-level"));
                    }
                    cli_log_level = Some(args[idx].clone());
                }
                "--log-file" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --log-file"));
                    }
                    cli_log_file = Some(args[idx].clone());
                }
                other => {
                    return Err(anyhow!(
                        "unknown argument '{}' for print-config (supported: --listen, --world-slug, --world-dir, --kubo-url, --log-level, --log-file)",
                        other
                    ));
                }
            }
            idx += 1;
        }

        let world_slug = if let Some(value) = cli_world_slug {
            value
        } else if let Ok(value) = std::env::var("MA_WORLD_SLUG") {
            value
        } else {
            DEFAULT_WORLD_SLUG.to_string()
        };

        let config_path = resolve_app_config_path(&world_slug, &cli_config_override);
        let cfg = load_app_config(&config_path)?;

        let listen = if let Some(v) = cli_listen {
            v
        } else if let Ok(v) = std::env::var("MA_LISTEN") {
            v
        } else if let Some(v) = cfg.listen {
            v
        } else {
            DEFAULT_LISTEN_ADDR.to_string()
        };

        let kubo_api_url = if let Some(v) = cli_kubo_url {
            v
        } else if let Ok(v) = std::env::var("MA_KUBO_API_URL") {
            v
        } else if let Some(v) = cfg.kubo_api_url {
            v
        } else {
            DEFAULT_KUBO_API_URL.to_string()
        };

        let world_dir = if let Some(v) = cli_world_dir {
            v
        } else if let Ok(v) = std::env::var("MA_WORLD_DIR") {
            PathBuf::from(v)
        } else if let Some(v) = cfg.world_dir {
            PathBuf::from(v)
        } else {
            default_world_dir(&world_slug)
        };

        let log_level = if let Some(v) = cli_log_level {
            v
        } else if let Ok(v) = std::env::var("MA_LOG_LEVEL") {
            v
        } else if let Some(v) = cfg.log_level {
            v
        } else {
            "info".to_string()
        };

        let log_file = if let Some(v) = cli_log_file {
            Some(v)
        } else if let Ok(v) = std::env::var("MA_LOG_FILE") {
            Some(v)
        } else {
            cfg.log_file
        };

        println!("kubo_api_url: {}", kubo_api_url);
        println!("listen: {}", listen);
        println!("world_slug: {}", world_slug);
        println!("world_dir: {}", world_dir.display());
        println!("log_level: {}", log_level);
        if let Some(v) = log_file {
            println!("log_file: {}", v);
        }
        return Ok(());
    }

    if args.len() >= 2 && args[1] == "print-effective-config" {
        let mut cli_listen: Option<String> = None;
        let mut cli_world_slug: Option<String> = None;
        let mut cli_world_dir: Option<PathBuf> = None;
        let mut cli_kubo_url: Option<String> = None;

        let mut idx = 2usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--listen" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --listen"));
                    }
                    cli_listen = Some(args[idx].clone());
                }
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    cli_world_slug = Some(args[idx].clone());
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    cli_world_dir = Some(PathBuf::from(&args[idx]));
                }
                "--kubo-url" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --kubo-url"));
                    }
                    cli_kubo_url = Some(args[idx].clone());
                }
                other => {
                    return Err(anyhow!(
                        "unknown argument '{}' for print-effective-config (supported: --listen, --world-slug, --world-dir, --kubo-url)",
                        other
                    ));
                }
            }
            idx += 1;
        }

        let (world_slug, world_slug_source) = if let Some(value) = cli_world_slug.clone() {
            (value, "cli".to_string())
        } else if let Ok(value) = std::env::var("MA_WORLD_SLUG") {
            (value, "env:MA_WORLD_SLUG".to_string())
        } else {
            (DEFAULT_WORLD_SLUG.to_string(), "default".to_string())
        };

        let config_path = resolve_app_config_path(&world_slug, &cli_config_override);
        let effective_app_config = load_app_config(&config_path)?;

        let (listen, listen_source) = if let Some(value) = cli_listen.clone() {
            (value, "cli".to_string())
        } else if let Ok(value) = std::env::var("MA_LISTEN") {
            (value, "env:MA_LISTEN".to_string())
        } else if let Some(value) = effective_app_config.listen.clone() {
            (value, "config:listen".to_string())
        } else {
            (DEFAULT_LISTEN_ADDR.to_string(), "default".to_string())
        };

        let (kubo_url, kubo_url_source) = if let Some(value) = cli_kubo_url.clone() {
            (value, "cli".to_string())
        } else if let Ok(value) = std::env::var("MA_KUBO_API_URL") {
            (value, "env:MA_KUBO_API_URL".to_string())
        } else if let Some(value) = effective_app_config.kubo_api_url.clone() {
            (value, "config:kubo_api_url".to_string())
        } else {
            (DEFAULT_KUBO_API_URL.to_string(), "default".to_string())
        };

        let (world_dir, world_dir_source) = if let Some(value) = cli_world_dir {
            (value, "cli".to_string())
        } else {
            (default_world_dir(&world_slug), "derived:default_world_dir(world_slug)".to_string())
        };

        let (log_level, log_level_source) = if let Ok(value) = std::env::var("MA_LOG_LEVEL") {
            (value, "env:MA_LOG_LEVEL".to_string())
        } else if let Some(value) = effective_app_config.log_level.clone() {
            (value, "config:log_level".to_string())
        } else {
            ("info".to_string(), "default".to_string())
        };

        let (log_file, log_file_source) = if let Ok(value) = std::env::var("MA_LOG_FILE") {
            (value, "env:MA_LOG_FILE".to_string())
        } else if let Some(value) = effective_app_config.log_file.clone() {
            (value, "config:log_file".to_string())
        } else {
            ("(none)".to_string(), "default".to_string())
        };

        println!("world_slug: {}", world_slug);
        println!("world_slug_source: {}", world_slug_source);
        println!("listen: {}", listen);
        println!("listen_source: {}", listen_source);
        println!("world_dir: {}", world_dir.display());
        println!("world_dir_source: {}", world_dir_source);
        println!("kubo_api_url: {}", kubo_url);
        println!("kubo_api_url_source: {}", kubo_url_source);
        println!("log_level: {}", log_level);
        println!("log_level_source: {}", log_level_source);
        println!("log_file: {}", log_file);
        println!("log_file_source: {}", log_file_source);
        return Ok(());
    }

    if args.len() >= 2 && args[1] == "check-kubo-ipns" {
        let mut world_slug = default_world_slug.clone();
        let mut world_dir_override: Option<PathBuf> = None;
        let mut key_override: Option<String> = None;
        let mut ipns_timeout_ms: u64 = 15_000;
        let mut ipns_retries: u32 = 3;
        let mut ipns_backoff_ms: u64 = 1_000;

        let mut idx = 2usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    world_slug = args[idx].clone();
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    world_dir_override = Some(PathBuf::from(&args[idx]));
                }
                "--key" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --key"));
                    }
                    key_override = Some(args[idx].clone());
                }
                "--ipns-timeout-ms" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --ipns-timeout-ms"));
                    }
                    ipns_timeout_ms = args[idx]
                        .parse()
                        .map_err(|e| anyhow!("invalid --ipns-timeout-ms: {}", e))?;
                }
                "--ipns-retries" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --ipns-retries"));
                    }
                    ipns_retries = args[idx]
                        .parse()
                        .map_err(|e| anyhow!("invalid --ipns-retries: {}", e))?;
                }
                "--ipns-backoff-ms" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --ipns-backoff-ms"));
                    }
                    ipns_backoff_ms = args[idx]
                        .parse()
                        .map_err(|e| anyhow!("invalid --ipns-backoff-ms: {}", e))?;
                }
                other => {
                    return Err(anyhow!(
                        "unknown argument '{}' for check-kubo-ipns (supported: --world-slug, --world-dir, --key, --ipns-timeout-ms, --ipns-retries, --ipns-backoff-ms)",
                        other
                    ));
                }
            }
            idx += 1;
        }

        let world_dir = world_dir_override.unwrap_or_else(|| default_world_dir(&world_slug));
        let loaded = load_world_authoring(&world_dir)?;
        let kubo_url = loaded.config.kubo.api_url.clone();
        let key_name = key_override.unwrap_or_else(|| loaded.config.kubo.world_ipns_key_name.clone());

        let available = list_kubo_key_names(&kubo_url).await?;
        if !available.iter().any(|candidate| candidate == &key_name) {
            return Err(anyhow!(
                "Kubo key '{}' is missing (run ensure-kubo-keys first)",
                key_name
            ));
        }

        let probe = serde_json::json!({
            "kind": "ma.kubo-healthcheck.v1",
            "timestamp": Utc::now().to_rfc3339(),
            "world": loaded.world_manifest.world_id,
        });
        let probe_cid = dag_put_dag_cbor(&kubo_url, &probe).await?;

        let ipns_options = IpnsPublishOptions {
            timeout: Duration::from_millis(ipns_timeout_ms),
            ..IpnsPublishOptions::default()
        };
        let published = ipns_publish_with_retry(
            &kubo_url,
            &key_name,
            &probe_cid,
            &ipns_options,
            ipns_retries,
            Duration::from_millis(ipns_backoff_ms),
        )
        .await?;

        println!("check-kubo-ipns OK");
        println!("  key: {}", key_name);
        println!("  probe_cid: {}", probe_cid);
        println!("  published: {}", published);
        println!("  retries: {}", ipns_retries);
        println!("  timeout_ms: {}", ipns_timeout_ms);
        return Ok(());
    }

    if args.len() >= 2 && args[1] == "init-world" {
        let mut world_slug = default_world_slug.clone();
        let mut world_dir_override: Option<PathBuf> = None;
        let mut force = false;
        let mut kubo_url = default_kubo_url.clone();

        let mut idx = 2usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    world_slug = args[idx].clone();
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    world_dir_override = Some(PathBuf::from(&args[idx]));
                }
                "--force" => {
                    force = true;
                }
                "--kubo-url" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --kubo-url"));
                    }
                    kubo_url = args[idx].clone();
                }
                other => {
                    return Err(anyhow!(
                        "unknown argument '{}' for init-world (supported: --world-slug, --world-dir, --force, --kubo-url)",
                        other
                    ));
                }
            }
            idx += 1;
        }

        let world_dir = world_dir_override.unwrap_or_else(|| default_world_dir(&world_slug));
        let resolved = resolve_world_identity_from_kubo(&kubo_url, &world_slug).await?;
        let report = init_world_skeleton(&world_dir, &world_slug, &resolved.world, force)?;
        println!("init-world OK");
        println!("  world_dir: {}", report.world_dir.display());
        println!("  world_slug: {}", report.world_slug);
        println!("  world_ipns_key_name: {}", report.world_ipns_key_name);
        println!("  world_id: {}", report.world_id);
        println!("  lobby_id: {}", report.lobby_id);
        return Ok(());
    }

    if args.len() >= 2 && args[1] == "ensure-kubo-keys" {
        let mut world_slug = default_world_slug.clone();
        let mut world_dir_override: Option<PathBuf> = None;

        let mut idx = 2usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    world_slug = args[idx].clone();
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    world_dir_override = Some(PathBuf::from(&args[idx]));
                }
                other => {
                    return Err(anyhow!(
                        "unknown argument '{}' for ensure-kubo-keys (supported: --world-slug, --world-dir)",
                        other
                    ));
                }
            }
            idx += 1;
        }

        let world_dir = world_dir_override.unwrap_or_else(|| default_world_dir(&world_slug));
        let loaded = load_world_authoring(&world_dir)?;
        let kubo_url = loaded.config.kubo.api_url.clone();
        let mut available = list_kubo_key_names(&kubo_url).await?;

        let mut expected = loaded.config.kubo.required_keys.clone();
        expected.push(loaded.config.kubo.world_ipns_key_name.clone());
        for actor in loaded.actors.values() {
            if actor.actor_type != "room" {
                continue;
            }
            if let Some(fragment) = did_fragment(&actor.id) {
                expected.push(fragment.to_string());
            }
        }
        expected.sort();
        expected.dedup();

        let mut created = Vec::new();
        for key in &expected {
            if available.iter().any(|candidate| candidate == key) {
                continue;
            }
            generate_kubo_key(&kubo_url, key).await?;
            created.push(key.clone());
            available.push(key.clone());
        }

        println!("ensure-kubo-keys OK");
        if created.is_empty() {
            println!("  created: (none)");
        } else {
            println!("  created: {}", created.join(", "));
        }
        println!("  required: {}", expected.join(", "));
        return Ok(());
    }

    if args.len() >= 2 && args[1] == "check-kubo-keys" {
        let mut world_slug = default_world_slug.clone();
        let mut world_dir_override: Option<PathBuf> = None;

        let mut idx = 2usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    world_slug = args[idx].clone();
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    world_dir_override = Some(PathBuf::from(&args[idx]));
                }
                other => {
                    return Err(anyhow!(
                        "unknown argument '{}' for check-kubo-keys (supported: --world-slug, --world-dir)",
                        other
                    ));
                }
            }
            idx += 1;
        }

        let world_dir = world_dir_override.unwrap_or_else(|| default_world_dir(&world_slug));
        let loaded = load_world_authoring(&world_dir)?;
        let available = list_kubo_key_names(&loaded.config.kubo.api_url).await?;

        let mut expected = loaded.config.kubo.required_keys.clone();
        expected.push(loaded.config.kubo.world_ipns_key_name.clone());
        for actor in loaded.actors.values() {
            if actor.actor_type != "room" {
                continue;
            }
            if let Some(fragment) = did_fragment(&actor.id) {
                expected.push(fragment.to_string());
            }
        }
        expected.sort();
        expected.dedup();

        let missing = expected
            .iter()
            .filter(|key| !available.iter().any(|candidate| candidate == *key))
            .cloned()
            .collect::<Vec<_>>();

        if !missing.is_empty() {
            return Err(anyhow!(
                "missing Kubo key(s): {}",
                missing.join(", ")
            ));
        }

        println!("kubo key check OK");
        println!("  required: {}", expected.join(", "));
        return Ok(());
    }

    if args.len() >= 2 && args[1] == "publish-world" {
        let mut world_slug = default_world_slug.clone();
        let mut world_dir_override: Option<PathBuf> = None;
        let mut skip_ipns = false;
        let mut allow_partial_ipns = false;
        let mut ipns_timeout_ms: u64 = 15_000;
        let mut ipns_retries: u32 = 3;
        let mut ipns_backoff_ms: u64 = 1_000;

        let mut idx = 2usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    world_slug = args[idx].clone();
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    world_dir_override = Some(PathBuf::from(&args[idx]));
                }
                "--skip-ipns" => {
                    skip_ipns = true;
                }
                "--allow-partial-ipns" => {
                    allow_partial_ipns = true;
                }
                "--ipns-timeout-ms" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --ipns-timeout-ms"));
                    }
                    ipns_timeout_ms = args[idx]
                        .parse()
                        .map_err(|e| anyhow!("invalid --ipns-timeout-ms: {}", e))?;
                }
                "--ipns-retries" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --ipns-retries"));
                    }
                    ipns_retries = args[idx]
                        .parse()
                        .map_err(|e| anyhow!("invalid --ipns-retries: {}", e))?;
                }
                "--ipns-backoff-ms" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --ipns-backoff-ms"));
                    }
                    ipns_backoff_ms = args[idx]
                        .parse()
                        .map_err(|e| anyhow!("invalid --ipns-backoff-ms: {}", e))?;
                }
                other => {
                    return Err(anyhow!(
                        "unknown argument '{}' for publish-world (supported: --world-slug, --world-dir, --skip-ipns, --allow-partial-ipns, --ipns-timeout-ms, --ipns-retries, --ipns-backoff-ms)",
                        other
                    ));
                }
            }
            idx += 1;
        }

        let world_dir = world_dir_override.unwrap_or_else(|| default_world_dir(&world_slug));
        let mut loaded = load_world_authoring(&world_dir)?;
        let kubo_url = loaded.config.kubo.api_url.clone();

        let mut actor_cids: HashMap<String, String> = HashMap::new();
        let actor_ids = loaded.actors.keys().cloned().collect::<Vec<_>>();
        for actor_id in actor_ids {
            let actor = loaded
                .actors
                .get(&actor_id)
                .ok_or_else(|| anyhow!("missing actor payload for {}", actor_id))?;
            let cid = dag_put_dag_cbor(&kubo_url, actor).await?;
            actor_cids.insert(actor_id, cid);
        }

        for (actor_id, item) in &mut loaded.actor_registry.actors {
            if let Some(cid) = actor_cids.get(actor_id) {
                item.cid = cid.clone();
            }
        }

        let actor_registry_cid = dag_put_dag_cbor(&kubo_url, &loaded.actor_registry).await?;
        loaded.world_root.refs.actor_registry_cid = actor_registry_cid.clone();
        let world_root_cid = dag_put_dag_cbor(&kubo_url, &loaded.world_root).await?;

        loaded.world_manifest.world_root_cid = world_root_cid.clone();
        loaded.world_manifest.refs.actor_registry_cid = actor_registry_cid.clone();
        let world_manifest_cid = dag_put_dag_cbor(&kubo_url, &loaded.world_manifest).await?;

        let mut ipns_failures: Vec<String> = Vec::new();
        let ipns_options = IpnsPublishOptions {
            timeout: Duration::from_millis(ipns_timeout_ms),
            ..IpnsPublishOptions::default()
        };

        if loaded.config.publish.publish_world_ipns && !skip_ipns {
            let available = list_kubo_key_names(&kubo_url).await?;
            let mut required = loaded.config.kubo.required_keys.clone();
            required.push(loaded.config.kubo.world_ipns_key_name.clone());
            for actor in loaded.actors.values() {
                if actor.actor_type != "room" {
                    continue;
                }
                if let Some(fragment) = did_fragment(&actor.id) {
                    required.push(fragment.to_string());
                }
            }
            required.sort();
            required.dedup();
            let missing = required
                .iter()
                .filter(|key| !available.iter().any(|candidate| candidate == *key))
                .cloned()
                .collect::<Vec<_>>();
            if !missing.is_empty() {
                let missing_msg = format!("cannot publish IPNS: missing Kubo key(s): {}", missing.join(", "));
                if allow_partial_ipns {
                    ipns_failures.push(missing_msg);
                } else {
                    return Err(anyhow!(missing_msg));
                }
            }

            if ipns_failures.is_empty() {
                match ipns_publish_with_retry(
                    &kubo_url,
                    &loaded.config.kubo.world_ipns_key_name,
                    &world_manifest_cid,
                    &ipns_options,
                    ipns_retries,
                    Duration::from_millis(ipns_backoff_ms),
                )
                .await
                {
                    Ok(published) => println!("world manifest published to IPNS: {}", published),
                    Err(err) => {
                        let msg = format!(
                            "world manifest IPNS publish failed (key={}): {}",
                            loaded.config.kubo.world_ipns_key_name,
                            err
                        );
                        if allow_partial_ipns {
                            ipns_failures.push(msg);
                        } else {
                            return Err(anyhow!(msg));
                        }
                    }
                }

                for actor in loaded.actors.values() {
                    if actor.actor_type != "room" {
                        continue;
                    }
                    let room_key = did_fragment(&actor.id)
                        .ok_or_else(|| anyhow!("room actor id missing fragment: {}", actor.id))?;
                    let room_cid = actor_cids
                        .get(&actor.id)
                        .ok_or_else(|| anyhow!("missing actor cid for room {}", actor.id))?;
                    match ipns_publish_with_retry(
                        &kubo_url,
                        room_key,
                        room_cid,
                        &ipns_options,
                        ipns_retries,
                        Duration::from_millis(ipns_backoff_ms),
                    )
                    .await
                    {
                        Ok(room_published) => {
                            println!("room actor published to IPNS ({}): {}", room_key, room_published)
                        }
                        Err(err) => {
                            let msg = format!(
                                "room actor IPNS publish failed (key={}): {}",
                                room_key, err
                            );
                            if allow_partial_ipns {
                                ipns_failures.push(msg);
                            } else {
                                return Err(anyhow!(msg));
                            }
                        }
                    }
                }
            }
        } else {
            println!("skipped IPNS publish (publish_world_ipns=false or --skip-ipns)");
        }

        if ipns_failures.is_empty() {
            println!("publish-world OK");
        } else {
            println!("publish-world PARTIAL (IPFS/IPLD succeeded; IPNS had issues)");
            for failure in &ipns_failures {
                println!("  ipns_issue: {}", failure);
            }
        }
        println!("  world_dir: {}", loaded.world_dir.display());
        println!("  actor_registry_cid: {}", actor_registry_cid);
        println!("  world_root_cid: {}", world_root_cid);
        println!("  world_manifest_cid: {}", world_manifest_cid);
        if loaded.config.publish.publish_world_ipns && !skip_ipns {
            println!("  ipns_retries: {}", ipns_retries);
            println!("  ipns_timeout_ms: {}", ipns_timeout_ms);
            println!("  ipns_backoff_ms: {}", ipns_backoff_ms);
            println!("  allow_partial_ipns: {}", allow_partial_ipns);
        }
        return Ok(());
    }

    if args.len() >= 2 && args[1] == "validate-world" {
        let mut world_slug = default_world_slug.clone();
        let mut world_dir_override: Option<PathBuf> = None;

        let mut idx = 2usize;
        while idx < args.len() {
            match args[idx].as_str() {
                "--world-slug" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-slug"));
                    }
                    world_slug = args[idx].clone();
                }
                "--world-dir" => {
                    idx += 1;
                    if idx >= args.len() {
                        return Err(anyhow!("missing value for --world-dir"));
                    }
                    world_dir_override = Some(PathBuf::from(&args[idx]));
                }
                other => {
                    return Err(anyhow!(
                        "unknown argument '{}' for validate-world (supported: --world-slug, --world-dir)",
                        other
                    ));
                }
            }
            idx += 1;
        }

        let world_dir = world_dir_override.unwrap_or_else(|| default_world_dir(&world_slug));
        let report = validate_world_authoring(&world_dir)?;
        println!("world schema validation OK");
        println!("  world_dir: {}", report.world_dir);
        println!("  config: {}", report.config_path);
        println!("  authoring: {}", report.authoring_dir);
        println!("  actors: {}", report.actor_count);
        return Ok(());
    }

    if args.len() >= 2 && !run_arg_mode {
        return Err(anyhow!(
            "unknown command '{}'. Use --help to list available commands.",
            args[1]
        ));
    }

    // Initialize logging with configurable level and optional file output
    let directive = format!("ma_world={}", log_level);
    let env_filter = tracing_subscriber::EnvFilter::from_default_env()
        .add_directive(directive.parse()?);

    if let Some(log_file_path) = &log_file {
        // Create parent directory if it doesn't exist
        if let Some(parent) = log_file_path.parent() {
            fs::create_dir_all(parent)?;
        }
        let file = fs::OpenOptions::new()
            .create(true)
            .append(true)
            .open(&log_file_path)?;

        let stdout_layer = tracing_subscriber::fmt::layer()
            .with_target(false)
            .with_thread_ids(false)
            .with_file(true)
            .with_line_number(true)
            .with_ansi(true)
            .with_writer(std::io::stdout);

        let file_layer = tracing_subscriber::fmt::layer()
            .with_target(false)
            .with_thread_ids(false)
            .with_file(true)
            .with_line_number(true)
            .with_ansi(false)
            .with_writer(file);

        tracing_subscriber::registry()
            .with(env_filter)
            .with(stdout_layer)
            .with(file_layer)
            .init();
    } else {
        tracing_subscriber::fmt()
            .with_env_filter(env_filter)
            .with_target(false)
            .with_thread_ids(false)
            .with_file(true)
            .with_line_number(true)
            .with_ansi(true)
            .init();
    }

    info!("Starting ma-world server");
    info!("Log level: {}", log_level);
    if let Some(log_path) = &log_file {
        info!("Logging to file: {}", log_path.display());
    }
    if app_config_exists {
        info!("Using config file {}", app_config_path.display());
    }

    let kubo_url = std::env::var("MA_KUBO_API_URL").unwrap_or_else(|_| default_kubo_url.clone());
    let entry_acl = load_entry_acl()?;
    let world = Arc::new(World::new(entry_acl));
        if let Some(ref did) = app_config.owner_did {
            *world.owner_did.write().await = Some(did.clone());
            info!("World owner DID: {}", did);
        }
    let authored_world_slug = run_world_slug_override
        .or_else(|| std::env::var("MA_WORLD_SLUG").ok())
        .unwrap_or_else(|| default_world_slug.clone());
    let authored_world_dir = run_world_dir_override
        .unwrap_or_else(|| default_world_dir(&authored_world_slug));
    info!(
        "Authored world source: slug='{}' dir='{}'",
        authored_world_slug,
        authored_world_dir.display()
    );
    let authored_config = if !authored_world_dir.exists() {
        warn!(
            "Authored world dir does not exist: {} (bootstrapping skeleton world)",
            authored_world_dir.display()
        );
        let resolved = resolve_world_identity_from_kubo(&kubo_url, &authored_world_slug).await?;
        let report = init_world_skeleton(&authored_world_dir, &authored_world_slug, &resolved.world, false)?;
        info!(
            "Initialized world skeleton: world_id={} lobby_id={}",
            report.world_id, report.lobby_id
        );
        Some(load_world_authoring(&authored_world_dir)?)
    } else if authored_world_dir.join("config.yaml").exists() {
        Some(load_world_authoring(&authored_world_dir)?)
    } else {
        warn!(
            "No config.yaml found in {} (bootstrapping skeleton world)",
            authored_world_dir.display()
        );
        let resolved = resolve_world_identity_from_kubo(&kubo_url, &authored_world_slug).await?;
        let report = init_world_skeleton(&authored_world_dir, &authored_world_slug, &resolved.world, false)?;
        info!(
            "Initialized world skeleton: world_id={} lobby_id={}",
            report.world_id, report.lobby_id
        );
        Some(load_world_authoring(&authored_world_dir)?)
    };

    if let Some(loaded) = authored_config.as_ref() {
        let unlocked = unlock_actor_secret_bundles(loaded)?;
        world.install_actor_secrets(&unlocked).await?;
        info!("Unlocked {} sealed actor secret bundle(s)", unlocked.len());

        for actor_id in unlocked.keys() {
            if let Some(fp) = world.actor_secret_fingerprint(actor_id).await {
                debug!("Actor secret loaded: {} key_fp={}", actor_id, fp);
            }
        }
        info!("Actor secret registry ready with {} actors", world.actor_secret_count().await);
    }

    if let Some(loaded) = authored_config.as_ref() {
        let mut created_any = false;
        for actor in loaded.actors.values() {
            if actor.actor_type != "room" {
                continue;
            }
            let room_name = actor_room_name(&actor.id);
            if room_name.is_empty() {
                continue;
            }
            world.create_room(room_name).await?;
            created_any = true;
        }
        if !created_any {
            world.create_room(DEFAULT_ROOM.to_string()).await?;
        }
    } else {
        world.create_room(DEFAULT_ROOM.to_string()).await?;
    }

    // Bind status listener before iroh endpoint setup so listen failures abort early.
    let listener = bind_status_listener(&listen_addr).await?;
    let status_addr = listener.local_addr()?;
    let status_url = format!("http://{}", status_addr);

    let key_path = if let Some(loaded) = authored_config.as_ref() {
        world_iroh_secret_key_path(&loaded.world_dir, &loaded.config.paths.secrets_dir)
    } else {
        legacy_iroh_secret_key_path()
    };
    let endpoint = if let Some(secret_key) = load_persisted_iroh_secret_key(&key_path)? {
        info!("Loaded persistent iroh identity from {}", key_path.display());
        Endpoint::builder(presets::N0)
            .secret_key(secret_key)
            .bind()
            .await?
    } else {
        let endpoint = Endpoint::bind(presets::N0).await?;
        persist_iroh_secret_key(&key_path, endpoint.secret_key())?;
        info!("Created persistent iroh identity at {}", key_path.display());
        endpoint
    };

    let endpoint_id = endpoint.id().to_string();
    let router = Router::builder(endpoint.clone())
        .accept(
            WORLD_ALPN,
            WorldProtocol {
                world: world.clone(),
                endpoint_id: endpoint_id.clone(),
                kubo_url: kubo_url.clone(),
                did_cache: Arc::new(RwLock::new(HashMap::new())),
            },
        )
        .spawn();
    let online_started = Instant::now();
    let online_status = match tokio::time::timeout(Duration::from_secs(10), endpoint.online()).await {
        Ok(_) => format!("ok in {}ms", online_started.elapsed().as_millis()),
        Err(_) => format!("timeout after {}ms", online_started.elapsed().as_millis()),
    };
    let endpoint_addr = endpoint.addr();

    let direct_addresses = endpoint_addr
        .ip_addrs()
        .map(|addr| addr.to_string())
        .collect::<Vec<_>>();
    let multiaddrs = endpoint_addr
        .ip_addrs()
        .map(socket_addr_to_multiaddr)
        .collect::<Vec<_>>();
    let relay_urls = endpoint_addr
        .relay_urls()
        .map(|url| url.to_string())
        .collect::<Vec<_>>();

    let world_info = WorldInfo {
        name: authored_config
            .as_ref()
            .map(|w| w.world_manifest.meta.name.clone())
            .unwrap_or_else(|| "ma-world".to_string()),
        status_url: status_url.clone(),
        endpoint_id: endpoint_id.clone(),
        direct_addresses,
        multiaddrs,
        relay_urls,
        kubo_url: kubo_url.clone(),
        location_hint: format!("/iroh/{endpoint_id}"),
        entry_acl: world.entry_acl_source().to_string(),
        started_at: Utc::now().to_rfc3339(),
    };

    let status_world = world.clone();
    let status_info = world_info.clone();
    tokio::spawn(async move {
        if let Err(err) = status::serve(listener, status_world, status_info).await {
            error!("status server failed: {}", err);
        }
    });

    info!("Created default room: {}", DEFAULT_ROOM);
    info!("World endpoint id: {}", world_info.endpoint_id);
    info!("World status page: {}", world_info.status_url);
    info!("World protocol ALPN: {}", String::from_utf8_lossy(WORLD_ALPN));
    info!("World entry ACL: {}", world_info.entry_acl);
    info!("Optional DID field ma:presenceHint = {}", world_info.location_hint);
    info!("Iroh online readiness: {}", online_status);

    for relay_url in &world_info.relay_urls {
        let probe = probe_relay(relay_url).await;
        info!("Relay probe {} -> {}", relay_url, probe);
    }

    println!("\n╔══════════════════════════════════════════════════════════╗");
    println!("║ ma-world Server                                         ║");
    println!("║ status page:   {:<41} ║", trim_console(&world_info.status_url, 41));
    println!("║ kubo API:      {:<41} ║", trim_console(&world_info.kubo_url, 41));
    println!("╚══════════════════════════════════════════════════════════╝");
    println!("world endpoint full: {}\n", world_info.endpoint_id);

    world
        .record_event(format!("world online at {}", world_info.status_url))
        .await;
    world
        .record_event(format!("iroh online readiness: {}", online_status))
        .await;
    world
        .record_event(format!("world direct addrs: {}", world_info.direct_addresses.join(", ")))
        .await;
    world
        .record_event(format!("world relays: {}", world_info.relay_urls.join(", ")))
        .await;
    for relay_url in &world_info.relay_urls {
        let probe = probe_relay(relay_url).await;
        world
            .record_event(format!("relay probe {} -> {}", relay_url, probe))
            .await;
    }
    world
        .record_event(format!("entry acl: {}", world_info.entry_acl))
        .await;
    world
        .record_event(format!("optional published location hint: {}", world_info.location_hint))
        .await;
    world
        .record_event(format!("world protocol ready on ALPN {}", String::from_utf8_lossy(WORLD_ALPN)))
        .await;

    info!("World initialized. Waiting for connections...");
    tokio::signal::ctrl_c().await?;
    info!("Shutting down ma-world");

    router.shutdown().await?;
    endpoint.close().await;
    Ok(())
}

fn actor_room_name(actor_id: &str) -> String {
    let fragment = actor_id
        .split('#')
        .nth(1)
        .unwrap_or(actor_id)
        .trim()
        .to_string();

    // Keep the runtime default room name stable even when actor IDs are key-prefixed
    // (e.g. did:...#panteia-lobby, did:...#ma-world-lobby).
    if fragment.eq_ignore_ascii_case("lobby") || fragment.ends_with("-lobby") {
        return DEFAULT_ROOM.to_string();
    }

    fragment
}

async fn bind_status_listener(listen_addr: &str) -> Result<TcpListener> {
    let socket: SocketAddr = listen_addr
        .parse()
        .map_err(|e| anyhow!("invalid --listen '{}': {}", listen_addr, e))?;
    TcpListener::bind(socket)
        .await
        .map_err(|e| anyhow!("failed to bind status listener on {}: {}", socket, e))
}

fn format_system_time(time: SystemTime) -> String {
    match time.duration_since(UNIX_EPOCH) {
        Ok(duration) => duration.as_secs().to_string(),
        Err(_) => "0".to_string(),
    }
}

fn socket_addr_to_multiaddr(addr: &SocketAddr) -> String {
    match addr.ip() {
        IpAddr::V4(ip) => format!("/ip4/{}/udp/{}/quic-v1", ip, addr.port()),
        IpAddr::V6(ip) => format!("/ip6/{}/udp/{}/quic-v1", ip, addr.port()),
    }
}

fn trim_console(input: &str, width: usize) -> String {
    let mut output = input.chars().take(width).collect::<String>();
    if output.len() < width {
        output.push_str(&" ".repeat(width - output.len()));
    }
    output
}

async fn probe_relay(relay_url: &str) -> String {
    let started = Instant::now();
    let client = match reqwest::Client::builder().timeout(RELAY_PROBE_TIMEOUT).build() {
        Ok(c) => c,
        Err(err) => return format!("client-build-error: {}", err),
    };

    match client.get(relay_url).send().await {
        Ok(resp) => format!("http {} in {}ms", resp.status().as_u16(), started.elapsed().as_millis()),
        Err(err) => format!("error {} in {}ms", err, started.elapsed().as_millis()),
    }
}

fn resolve_avatar_inbox(did: &Did) -> Result<String> {
    did.fragment
        .clone()
        .ok_or_else(|| anyhow!("sender DID must include #fragment (local avatar inbox atom)"))
}

fn load_entry_acl() -> Result<EntryAcl> {
    let raw = std::env::var(WORLD_ENTRY_ACL_ENV).unwrap_or_else(|_| DEFAULT_ENTRY_ACL.to_string());
    parse_entry_acl(&raw)
}

fn parse_entry_acl(raw: &str) -> Result<EntryAcl> {
    let tokens = raw
        .split(',')
        .map(|item| item.trim())
        .filter(|item| !item.is_empty())
        .collect::<Vec<_>>();

    if tokens.is_empty() {
        return Err(anyhow!(
            "{} is empty; use '*' or comma separated did:ma:... values",
            WORLD_ENTRY_ACL_ENV
        ));
    }

    let mut allow_all = false;
    let mut allowed_dids = HashSet::new();
    for token in tokens {
        if token == "*" {
            allow_all = true;
            continue;
        }

        let did = Did::try_from(token)?;
        allowed_dids.insert(did.without_fragment().id());
    }

    if !allow_all && allowed_dids.is_empty() {
        return Err(anyhow!(
            "{} must contain '*' or at least one valid DID",
            WORLD_ENTRY_ACL_ENV
        ));
    }

    Ok(EntryAcl {
        allow_all,
        allowed_dids,
        source: raw.trim().to_string(),
    })
}

fn world_iroh_secret_key_path(world_dir: &Path, secrets_dir: &str) -> PathBuf {
    let base = PathBuf::from(secrets_dir);
    if base.is_absolute() {
        return base.join(IROH_SECRET_KEY_FILENAME);
    }
    world_dir.join(base).join(IROH_SECRET_KEY_FILENAME)
}

fn legacy_iroh_secret_key_path() -> PathBuf {
    if let Some(state_home) = std::env::var_os("XDG_STATE_HOME") {
        return PathBuf::from(state_home)
            .join("ma-world")
            .join(IROH_SECRET_KEY_FILENAME);
    }

    if let Some(home) = std::env::var_os("HOME") {
        return PathBuf::from(home)
            .join(".local")
            .join("state")
            .join("ma-world")
            .join(IROH_SECRET_KEY_FILENAME);
    }

    PathBuf::from(".ma-world").join(IROH_SECRET_KEY_FILENAME)
}

fn load_persisted_iroh_secret_key(path: &PathBuf) -> Result<Option<SecretKey>> {
    if !path.exists() {
        return Ok(None);
    }

    let bytes = fs::read(path)?;
    let key_bytes: [u8; 32] = bytes
        .as_slice()
        .try_into()
        .map_err(|_| anyhow!("invalid iroh secret key file length in {}", path.display()))?;

    Ok(Some(SecretKey::from_bytes(&key_bytes)))
}

fn persist_iroh_secret_key(path: &PathBuf, secret_key: &SecretKey) -> Result<()> {
    if let Some(parent) = path.parent() {
        fs::create_dir_all(parent)?;
        #[cfg(unix)]
        {
            fs::set_permissions(parent, fs::Permissions::from_mode(0o700))?;
        }
    }

    fs::write(path, secret_key.to_bytes())?;
    #[cfg(unix)]
    {
        fs::set_permissions(path, fs::Permissions::from_mode(0o600))?;
    }
    Ok(())
}
